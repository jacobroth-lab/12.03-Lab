extends layout

block content
  h1= title

  p Welcome to #{title}
  
  ol

  each val in todos

    li(class=val.completed > 0 ? 'completed' : 'pending')

      span= val.task + ' - '

      if val.completed > 0
        span Completed
      else
        span Not Completed

      form(method='POST' action='/edit')
        input(type='hidden', name='id', value=val.id)
        input(type='text', name='task', value=val.task)
        button(type='submit') Edit

      if val.completed == 0

        form(method='POST' action='/complete')
          input(type='hidden', name='id', value=val.id)
          button(type='submit') Mark as Done

      form(method='POST' action='/delete')
        input(type='hidden', name='id', value=val.id)
        button(type='submit') Delete

  hr

  h2 Add a new task

  form(method='POST' action='/create')
    label(for='task') Task:
    input(type='text', name='task', id='task', required)
    button(type='submit') Create Task
